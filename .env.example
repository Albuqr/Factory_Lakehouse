# ---------------------------------------------------------------------------
# GCP credentials — use ONE of the two options below, not both.
# ---------------------------------------------------------------------------

# Option A — file path (local dev and Docker with volume mount)
# Local dev: relative path from project root
# Docker:    docker-compose sets this automatically via the volume mount
GOOGLE_APPLICATION_CREDENTIALS=./gcp-credentials.json

# Option B — JSON string (VPS / production, no file mount required)
# Generate with: python -c "import json,sys; print(json.dumps(json.load(open('gcp-credentials.json'))))"
# Then paste the single-line output as the value below.
# GCP_CREDENTIALS_JSON=

# ---------------------------------------------------------------------------
# Airflow alert email (optional — leave blank to disable failure emails)
# ---------------------------------------------------------------------------
AIRFLOW_ALERT_EMAIL=
